# Google Maps API Key
# Get your API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
# Enable these APIs in Google Cloud Console:
# - Maps JavaScript API
# - Places API
VITE_APP_GOOGLE_API_KEY=your_google_maps_api_key_here

# Example:
# VITE_APP_GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
